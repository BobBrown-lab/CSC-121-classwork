#9-14. Lottery

#import functions from library
import random
from random import randint
import string
from random import choice

#create list for winning numbers:

winning_numbers = []
#generate winning numbers list
x=0
while x <= 9:
    y = randint(1,11)
    winning_numbers.append(y)
    x +=1
print(winning_numbers) 

#generate winning letters list

winning_letters =[]
alphabet = string.ascii_lowercase
x=0
while x<= 3:
    y = random.choice(alphabet)
    winning_letters.append(y)
    x += 1
print(winning_letters)
print("\n")

#generate winning_ticket
x=0
winning_ticket = []
while x <= 3:
    a = choice(winning_numbers)
    winning_ticket.append(a)
    x += 1
print(winning_ticket)
b = choice(winning_letters)
winning_ticket.append(b)
print(winning_ticket)
